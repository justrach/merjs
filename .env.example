# merjs environment variables
#
# Copy this file to .env and fill in any values you need.
# These are optional — the framework runs without them.
#
# Example: add API keys for routes that call external services.
# MY_API_KEY=your_key_here
#
# On Cloudflare Workers: set secrets via `wrangler secret put MY_API_KEY`
# Locally: the dev server reads .env automatically.

# Sentry error tracking (optional — errors are reported when DSN is set)
# SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Datadog APM (optional — request metrics sent via DogStatsD UDP)
# DD_AGENT_HOST=127.0.0.1
# DD_DOGSTATSD_PORT=8125
