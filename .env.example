# OpenAI (embeddings + gpt-5-nano for AI chat)
# Get yours at: https://platform.openai.com
OPENAI_API_KEY=sk-proj-...

# EmergentDB (vector search for RAG)
# Get yours at: https://emergentdb.com
EMERGENT_API_KEY=emdb_...

# Singapore government datasets (optional — for /explore route)
# Get yours at: https://data.gov.sg
SG_DATA_API_KEY=your_key_here

# On Cloudflare Workers: set via `wrangler secret put OPENAI_API_KEY` etc.
# Locally: copy this file to .env and fill in values, then `zig build serve`
