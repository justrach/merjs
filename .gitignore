# Zig build artifacts
.zig-cache/
zig-out/

# Generated files (recreated by `zig build codegen`)
src/generated/*
!src/generated/.gitkeep

# Built assets (recreated by build steps)
public/styles.css
public/counter.wasm
public/synth.wasm
dist/

# Cloudflare Workers — compiled WASM output
worker/merjs.wasm
worker/grep.wasm
examples/kanban/worker/merjs.wasm
examples/singapore-data-dashboard/worker/merjs.wasm

# Toolchain binaries (downloaded on first build)
tools/tailwindcss

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Wrangler
.wrangler/
examples/**/worker/.wrangler/
examples/**/worker/.dev.vars
node_modules/

# Environment variables and secrets — never commit real values
.env
.env.local
.env.*.local
worker/.dev.vars
packages/merjs-auth/.dev.vars

# Socials / content drafts (internal)
socials/

# Stale build artifacts
test_config.o
.zigrep_archive
api.main/
app.main/
public/style.css
*.o
--version
