#!/bin/sh
# merjs pre-push hook — runs tests before pushing
# Install: git config core.hooksPath .githooks

set -e

echo "pre-push: running tests..."
if ! zig build test 2>&1; then
    echo ""
    echo "  pre-push: tests failed — fix before pushing"
    echo ""
    exit 1
fi

echo "pre-push: all tests passed"
